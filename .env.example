# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Storage bucket name (default: img)
# STORAGE_BUCKET=img

# How long signed image URLs stay valid, in seconds (default: 3600)
# SIGNED_URL_TTL=3600

# ── YOLO / Detection ──────────────────────────────────────────────────────────
# GPU detection server — REQUIRED, no local fallback
# Set to your Cloud Run service URL
# YOLO_SERVICE_URL=https://arcera-detect-738006847897.us-central1.run.app

# Shared secret for X-API-Key header — must match DETECT_API_KEY on Cloud Run
# DETECT_API_KEY=your-secret-key-here

# Seconds to wait for GPU detection server response (default: 30)
# DETECT_SERVICE_TIMEOUT=30

# ── File Uploads ──────────────────────────────────────────────────────────────
# Where uploaded images are saved locally (default: uploads/ at project root)
# UPLOAD_FOLDER=/abs/path/to/uploads

# Comma-separated list of accepted image extensions (default shown)
# VALID_EXTENSIONS=.jpg,.jpeg,.png,.webp,.bmp,.tiff
